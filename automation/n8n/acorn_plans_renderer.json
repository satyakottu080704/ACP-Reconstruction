              "id": "cond_img",
              "leftValue": "={{ $json.name }}",
              "rightValue": "\\.(jpe?g|png)$",
              "operator": {
                "type": "string",
                "operation": "regex"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter_image",
      "name": "Keep image attachments",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        1380,
        500
      ]
