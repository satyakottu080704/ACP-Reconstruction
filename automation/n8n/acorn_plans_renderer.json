    {
      "parameters": {
        "jsCode": "// Pick the sketch image per project = the LARGEST image for that project.\n// Surveyors attach a photo of the hand-drawn sketch (typically MB-sized);\n// inline email-signature logos are tiny (~40KB), so largest-by-size reliably\n// picks the real sketch. Non-inline wins ties. If only a tiny logo exists, the\n// pipeline refuses (0 rooms) and the email is routed to Manual Review.\nconst items = $input.all();\nconst byProject = new Map();\nfor (let i = 0; i < items.length; i++) {\n  const j = items[i].json;\n  let key;\n  try { key = $('Extract N-number').itemMatching(i).json.projectNumber; }\n  catch (e) { key = j.id; }\n  if (!byProject.has(key)) byProject.set(key, []);\n  byProject.get(key).push(items[i]);\n}\nconst out = [];\nfor (const [key, imgs] of byProject) {\n  imgs.sort((a, b) => {\n    const sa = Number(a.json.size) || 0, sb = Number(b.json.size) || 0;\n    if (sb !== sa) return sb - sa;                                  // largest first\n    return (a.json.isInline === true) - (b.json.isInline === true); // non-inline wins ties\n  });\n  out.push(imgs[0]);\n}\nreturn out;\n"
      },
      "id": "first_image",
      "name": "Pick sketch image (largest)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1580,
        500
      ]
    },
    {
      "parameters": {
        "resource": "messageAttachment",
        "operation": "download",
        "messageId": {
          "__rl": true,
          "value": "={{ $('Extract N-number').item.json.messageId }}",
          "mode": "id"
        },
        "attachmentId": "={{ $json.id }}"
      },
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        1780,
        500
      ],
      "id": "download_sketch",
      "name": "Download sketch",
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "FNq1tabrcjylXbSd",
          "name": "Plans-Acornhealthandsafety"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Per-project filename + carry projectNumber and messageId into json.\nconst items = $input.all();\nfor (let i = 0; i < items.length; i++) {\n  const ex = $('Extract N-number').itemMatching(i).json;\n  const pn = ex.projectNumber;\n  const mid = ex.messageId;\n  const b = items[i].binary && items[i].binary.data;\n  const ext = ((b && b.fileName ? b.fileName : 'x.jpg').split('.').pop() || 'jpg').toLowerCase();\n  const sketchFile = `${pn}_sketch.${ext}`;\n  if (b) b.fileName = sketchFile;\n  items[i].json = { ...items[i].json, projectNumber: pn, messageId: mid, sketchFile };\n}\nreturn items;"
      },
      "id": "name_sketch",
      "name": "Name sketch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1980,
        500
      ]
    },
